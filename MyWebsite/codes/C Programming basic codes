11. Armstrong Number
=========================================

#include <stdio.h>
#include <math.h>

int main() {
    int n, temp, rem, sum = 0;

    scanf("%d", &n);
    temp = n;

    while(temp != 0) {
        rem = temp % 10;
        sum += rem * rem * rem;
        temp /= 10;
    }

    if(sum == n)
        printf("Armstrong");
    else
        printf("Not Armstrong");

    return 0;
}

